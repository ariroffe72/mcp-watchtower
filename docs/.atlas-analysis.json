  "keyFeatures": [
    "Duplicate tool name detection across MCP server definitions",
    "Naming convention consistency checks (snake_case, camelCase, kebab-case)",
    "Parameter conflict detection using synonym groups",
    "Shadow pattern scanning to detect LLM tool-routing manipulation",
    "Tool count threshold warnings for LLM routing accuracy",
    "Local stdio server scanning (Python, Node.js, Go, any language)",
    "Remote HTTP MCP server scanning with bearer auth",
    "CI manifest mode for offline JSON-based analysis",
    "JSON output mode for programmatic consumption",
    "Platform mode for multi-server orchestrator environments",
    "Zero LLM calls — fully deterministic, offline analysis",
    "TypeScript library API for embedding in your own tooling"
  ],
  "publicApiSurface": [
    "npx mcp-watchtower scan --server <command>",
