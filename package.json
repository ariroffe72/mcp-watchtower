{
    "name": "mcp-watchtower",
    "version": "0.2.1",
    "description": "Static analysis and compatibility checks for MCP servers",
    "type": "module",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "bin": {
        "mcp-watchtower": "./dist/cli/index.js"
    },
    "files": [
        "dist/cli/",
        "dist/src/analyzers/",
        "dist/src/embeddings/",
        "dist/src/index-updater/",
        "dist/src/index.js",
        "dist/src/index.d.ts",
        "dist/src/types.js",
        "dist/src/types.d.ts",
        "dist/index.js",
        "dist/index.d.ts",
        "dist/types.js",
        "dist/types.d.ts",
        "src/data/semantic.hnsw",
        "src/data/semantic-meta.json",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "changeset": "changeset",
        "build": "npm run build:ts && npm run build:postbuild",
        "build:ts": "tsc",
        "build:postbuild": "node scripts/postbuild.mjs",
        "crawl": "node --env-file=.env dist/src/crawler/run.js",
        "embed": "node dist/src/embeddings/run.js",
        "crawl-and-embed": "npm run crawl && npm run embed",
        "build-index": "node dist/src/index-builder/run.js",
        "full-build": "npm run crawl && npm run embed && npm run build-index",
        "pack:check": "node scripts/verify-package.mjs",
        "publish-index": "node --env-file=.env dist/scripts/publish-index.js",
        "release:check": "npm run build && npm test && npm run pack:check",
        "release": "npm run build && npm test && npm run pack:check && changeset publish",
        "test": "vitest run",
        "test:watch": "vitest",
        "version-packages": "changeset version",
        "prepublishOnly": "npm run build && npm test && npm run pack:check"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "llm",
        "ai",
        "agents",
        "static-analysis",
        "lint"
    ],
    "engines": {
        "node": ">=18"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ariroffe72/mcp-lens.git"
    },
    "homepage": "https://github.com/ariroffe72/mcp-lens#readme",
    "bugs": {
        "url": "https://github.com/ariroffe72/mcp-lens/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.25.3",
        "@xenova/transformers": "^2.17.2",
        "better-sqlite3": "^12.9.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "hnswlib-node": "^3.0.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.5"
    }
}
