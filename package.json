{
  "name": "mcp-watchtower",
  "version": "0.1.0",
  "description": "Static analysis and compatibility checks for MCP servers",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "mcp-watchtower": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.copyFileSync('src/analyzers/shadow-patterns.json', 'dist/src/analyzers/shadow-patterns.json'); fs.cpSync('dist/src/crawler', 'dist/crawler', { recursive: true });\"",
    "crawl": "node --env-file=.env dist/crawler/run.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "agents",
    "static-analysis",
    "lint"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
